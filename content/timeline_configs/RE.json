	"EnumDefinitions": {},
	"ParameterInfos": {
		"StimulusType": {
			"Type": "Enum",
			"Values": [ "Digits", "LowerCaseLetters", "UpperCaseLetters", "BehaverseSymbolsDistinct" ]
		},
		"SequenceLength": {
			"Type": "Int",
			"Min": 1
		},
		"ItemSequence": {
			"Type": "Int",
			"Min": -27,
			"Max": 26
		},
		"StimulusColor": {
			"Type": "Color"
		},
		"DistractorColor": {
			"Type": "Color"
		},
		"StimulusDisplayDuration": {
			"Type": "Float",
			"Min": 0.01
		},
		"InterstimulusInterval": {
			"Type": "Float",
			"Min": 0
		},
		"NoiseMaskDisplayDuration": {
			"Type": "Float",
			"Min": 0
		},
		"ResponsePatterns": {
			"Type": "String",
			// Pattern is separated into two possibilities:
			// ([A-Z0-9]|![A-Z0-9]): Special case to handle cases with only one letter (X and !X)
			// [A-Z0-9]|![A-Z0-9])([A-Z0-9]|![A-Z0-9]|\\?|\\.|\\*)*[A-Z0-9]: All other cases, as such:
			// 		([A-Z0-9]|![A-Z0-9]): Start with a single letter (X or !X)
			//		([A-Z0-9]|![A-Z0-9]|\\?|\\.|\\*){0,3}: Follow up with any possible character (X, !X, ?, ., *), up to 3 times to prevent sequences more than 5 characters long
			//		([A-Z0-9]|![A-Z0-9]): Finish with a single letter (X or !X)
			"Pattern": "(([A-Za-z0-9]|![A-Za-z0-9])|([A-Za-z0-9]|![A-Za-z0-9])([A-Za-z0-9]|![A-Za-z0-9]|\\?|\\.|\\*)*([A-Za-z0-9]|![A-Za-z0-9]))"
		},
		"HidePatternTrialDelay": {
			"Type": "Int",
			"Min": 1
		},
		"UseNonMatchButton": {
			"Type": "Bool"
		},
		"ShowAccuracyCheckFeedback": {
			"Type": "Enum",
			"Name": "ShowAccuracyCheckFeedback"
		},
		"ShowAccuracyOnButtonFeedback": {
			"Type": "Enum",
			"Name": "ShowAccuracyCheckFeedback"
		},
		"ShowCorrectTrialResponseFeedback": {
            "Type": "Enum",
			"Values": [
                "Never",
                "OnError",
                "OnTimeout",
                "Always"
            ]
		},
		"ShowBlockStats": {
			"Type": "Bool"
		}
	},
