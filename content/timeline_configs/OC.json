		"XCIT_OC_Pilot6": {
			"Inherits": "XCIT_OC_01_Test",
			"Parameters":{
				"BlockTimer_Position": "StatusBarRight",
				"BlockTimer_Style": "TimeOnly"
			},
			"TrialOrder": [0,1,2,3,4,5,6,7]
		},
		"XCIT_OC_01_Test": {
			// note: this block has 8 defined trials (8 experimental conditions), we use trialOrder with a "repeat" sequence to produce shuffled pairs of trials
			// the 32 trials will have the structure: shuffle(00,11,22,33,44,55,66,77) + shuffle(00,11,22,33,44,55,66,77)
			// such as 1122445533667700 3344665577001122
			"Inherits": "XCIT_OC_Base",
			"Parameters":{"MaxResponseTimeAfterFirstClick": 30},
			"TrialOrder": {
				"Sequence": { // turns a a sequence such as 21504736 into 2211550044773366
					"Type": "Repeat",
					"SequenceLength": 32, 
					"Repeats": 2,
					"Values": { // produces a sequence such as 21504736
						"Replacement": "WithoutInBlock",
						"Distribution": {
							"Type": "Uniform"
						}
					} 
				}
			},
			"Trials":[ // 8 experimental conditions, DDS DDA LLS LLA DLS DLA LDS LDA
				{
					"Parameters": {
						"Streams": [
							{
								"FeatureType": "Digits",
								"SioBackgroundColor": "#eeeeee",
								"SioTextColor": "#444444",
								"AscendingOrder": true,
								"TrackStream": true
							},
							{
								"FeatureType": "Digits",
								"SioBackgroundColor": "#444444",
								"SioTextColor": "#eeeeee",
								"AscendingOrder": true,
								"TrackStream": true
							}
						],
						"OrderingRule": "Sequential"
					}
				},
				{
					"Parameters": {
						"Streams": [
							{
								"FeatureType": "Digits",
								"SioBackgroundColor": "#eeeeee",
								"SioTextColor": "#444444",
								"AscendingOrder": true,
								"TrackStream": true
							},
							{
								"FeatureType": "Digits",
								"SioBackgroundColor": "#444444",
								"SioTextColor": "#eeeeee",
								"AscendingOrder": true,
								"TrackStream": true
							}
						],
						"OrderingRule": "Alternate"
					}
				},
				{
					"Parameters": {
						"Streams": [
							{
								"FeatureType": "Letters",
